@page "/"

<PageTitle>Calculator</PageTitle>


<div class="calculator">
    <div class="display"></div>
    <div class="buttons">

        <button>7</button>
        <button>8</button>
        <button>9</button>
        <button>/</button>

        <button>4</button>
        <button>5</button>
        <button>6</button>
        <button>*</button>

        <button>1</button>
        <button>2</button>
        <button>3</button>
        <button>-</button>

        <button>C</button>
        <button>0</button>
        <button>,</button>
        <button>+</button>

        <button class="equals">=</button>
    </div>

</div>
